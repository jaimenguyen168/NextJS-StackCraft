// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String @id @default(cuid())
  userId      String
  name        String
  description String // what the user typed in

  // Generated outputs — stored as JSON so you can iterate on the shape freely
  techStack    Json?
  schema       Json? // DB schema + Prisma models
  timeline     Json? // phases, milestones
  architecture Json? // Mermaid diagram code
  erd          Json? // ERD diagram code
  apiStructure Json? // endpoints, methods, descriptions
  tasks        Json? // user stories / kanban cards

  status ProjectStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectStatus {
  PENDING // just created, not generated yet
  GENERATING // Modal is working on it
  COMPLETE // all sections generated
  FAILED // something went wrong
}
