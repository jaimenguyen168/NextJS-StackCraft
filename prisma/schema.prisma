generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id
  username  String  @unique
  name      String?
  email     String?
  imageUrl  String?
  githubUrl String?

  projects        Project[]
  collaboratingOn ProjectCollaborator[]
  subscriptions   UserSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String  @id @default(cuid())
  userId      String
  username    String
  name        String
  description String
  slug        String
  published   Boolean @default(false)

  // Metadata
  githubUrl      String?
  githubToken    String? // optional PAT for pushing docs to the repo
  logoUrl        String?
  mainColorLight String?
  mainColorDark  String?
  mainContent    String?
  links          ProjectLink[]
  tags           String[]
  collaborators  ProjectCollaborator[]
  images         ProjectImage[]

  contentBlocks ContentBlock[]
  sections      Section[]
  chats         ProjectChat[]

  status        ProjectStatus         @default(PENDING)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id])
  githubContext ProjectGithubContext?

  @@unique([username, slug])
}

model ProjectLink {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label String
  url   String
  order Int    @default(0)

  createdAt DateTime @default(now())
}

model ProjectCollaborator {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   CollaboratorRole   @default(VIEWER)
  status CollaboratorStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model ProjectGithubContext {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  githubUrl     String
  context       String // the full built context string
  commitSha     String? // latest commit SHA at time of import
  commitMessage String? // latest commit message or PR merge message
  branch        String? // branch that was imported

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CollaboratorStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url     String
  key     String // R2 object key for deletion
  caption String?
  order   Int     @default(0)

  createdAt DateTime @default(now())
}

model Section {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title String
  order Int

  parentId String?
  parent   Section?  @relation("SectionTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Section[] @relation("SectionTree")

  contentBlocks ContentBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentBlock {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  kind    ContentKind
  type    String
  title   String
  content String
  body    String?

  order Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectChat {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id     String      @id @default(cuid())
  chatId String
  chat   ProjectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role        MessageRole
  content     String
  snapshot    Json?
  tokensUsed  Int         @default(0)

  createdAt DateTime @default(now())
}

enum ContentKind {
  DOCUMENT
  DIAGRAM
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ProjectStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}

enum CollaboratorRole {
  OWNER
  EDITOR
  VIEWER
}

model UserSubscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
  plan   Plan   @default(FREE)

  // Generation credits
  manualCreditsUsed Int @default(0)
  githubCreditsUsed Int @default(0)

  // Edit token tracking (edits only, not generates)
  editTokensUsed Int @default(0)

  // Monthly reset
  periodStart DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Plan {
  FREE
  STARTER
  PRO
}
