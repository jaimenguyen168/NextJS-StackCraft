// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String

  diagrams    Diagram[]
  documents   Document[]

  status    ProjectStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      DocumentType
  title     String
  content   String       // Markdown — easy to copy into Notion/Docusaurus/GitHub

  order     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Diagram {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      DiagramType
  title     String
  content   String

  order     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DocumentType {
  OVERVIEW       // project summary + goals
  TECH_STACK     // stack choices + rationale
  TIMELINE       // phases + milestones
  API_STRUCTURE  // endpoints + descriptions
  TASKS          // user stories / breakdown
}

enum DiagramType {
  ARCHITECTURE
  ERD
  SEQUENCE
  FLOWCHART
}

enum ProjectStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}