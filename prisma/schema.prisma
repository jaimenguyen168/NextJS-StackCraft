generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String  @id @default(cuid())
  userId      String
  username    String
  name        String
  description String
  slug        String
  published   Boolean @default(false)

  contentBlocks ContentBlock[]
  sections      Section[]
  chats         ProjectChat[]

  status    ProjectStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([username, slug])
}

model Section {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title String
  order Int

  parentId String?
  parent   Section?  @relation("SectionTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Section[] @relation("SectionTree")

  contentBlocks ContentBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentBlock {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  kind    ContentKind
  type    String
  title   String
  content String
  body    String?

  order Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectChat {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id     String      @id @default(cuid())
  chatId String
  chat   ProjectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role     MessageRole
  content  String
  snapshot Json?

  createdAt DateTime @default(now())
}

enum ContentKind {
  DOCUMENT
  DIAGRAM
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ProjectStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}
