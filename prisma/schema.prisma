generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String @id @default(cuid())
  userId      String
  username    String
  name        String
  description String
  slug        String

  published Boolean @default(false)

  diagrams  Diagram[]
  documents Document[]
  chats     ProjectChat[]

  status    ProjectStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([username, slug])
}

model Document {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type    String
  title   String
  content String
  order   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Diagram {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type    String
  title   String
  content String
  order   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectChat {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id     String      @id @default(cuid())
  chatId String
  chat   ProjectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role    MessageRole
  content String

  // What changed at this moment
  snapshot Json?

  createdAt DateTime @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ProjectStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}
